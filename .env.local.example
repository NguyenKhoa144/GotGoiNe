# Copy file này thành .env.local rồi điền ID thật (file .env* đã bị .gitignore, không push lên GitHub).
# Thiếu ID nào thì script tương ứng sẽ không gắn vào site — không cần điền đủ cả 3 mới chạy được.

# Facebook Pixel ID — lấy tại business.facebook.com/events_manager
NEXT_PUBLIC_FB_PIXEL_ID=

# TikTok Pixel ID — lấy tại ads.tiktok.com > Assets > Events > Web Events
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Google Analytics 4 Measurement ID (dạng G-XXXXXXXXXX) — lấy tại analytics.google.com > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=
