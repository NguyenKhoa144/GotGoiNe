# Copy file này thành .env.local rồi điền ID thật (file .env* đã bị .gitignore, không push lên GitHub).
# Thiếu ID nào thì script tương ứng sẽ không gắn vào site — không cần điền đủ cả 3 mới chạy được.

# Facebook Pixel ID — lấy tại business.facebook.com/events_manager
NEXT_PUBLIC_FB_PIXEL_ID=

# TikTok Pixel ID — lấy tại ads.tiktok.com > Assets > Events > Web Events
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Google Analytics 4 Measurement ID (dạng G-XXXXXXXXXX) — lấy tại analytics.google.com > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Đăng nhập admin (/admin/poster) ---

# Khóa ký session, bắt buộc. Tạo bằng: openssl rand -base64 32
AUTH_SECRET=

# Tên đăng nhập admin, tự đặt tuỳ ý
ADMIN_USERNAME=

# Hash bcrypt của mật khẩu admin, mã hoá base64 — KHÔNG điền mật khẩu thật vào đây.
# Lưu ý: hash bcrypt gốc chứa nhiều dấu $ (vd: $2b$10$...), mà bộ đọc file .env của
# Next.js lại hiểu dấu $ là tham chiếu biến nên sẽ làm hỏng giá trị nếu để nguyên —
# vì vậy phải mã hoá base64 trước khi lưu vào đây.
# Tạo bằng lệnh (chạy sau khi đã `npm install`), thay MẬT_KHẨU_CỦA_BẠN bằng mật khẩu thật:
#   node -e "require('bcryptjs').hash('MẬT_KHẨU_CỦA_BẠN', 10).then(h => console.log(Buffer.from(h).toString('base64')))"
# rồi dán kết quả (chuỗi base64, không có dấu $) vào đây.
ADMIN_PASSWORD_HASH_B64=
